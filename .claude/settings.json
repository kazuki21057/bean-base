{
  "permissions": {
    "allow": [
      "Bash",
      "PowerShell",
      "Bash(flutter analyze *)",
      "Bash(flutter test *)",
      "Bash(flutter pub get)",
      "Bash(dart run build_runner build *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git check-ignore *)",
      "Bash(node .claude/hooks/loop_guard.js)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(git checkout -- *)",
      "PowerShell(Remove-Item *)",
      "PowerShell(git push * --force*)",
      "PowerShell(git reset --hard*)",
      "PowerShell(git clean -f*)",
      "PowerShell(git branch -D*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/loop_guard.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/loop_guard.js"
          }
        ]
      }
    ]
  }
}
